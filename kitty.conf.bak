# ctrl + shift + f5 to refresh kitty after config change
# kitten themes to switch theme
# kitten icat for images

# BEGIN_KITTY_THEME
# Liquid Carbon Transparent
include current-theme.conf
# END_KITTY_THEME
#

# shell
shell /usr/bin/bash

# Font
# Unzip fonts to ~/.fonts
# update cache with `fc-cache -fv`
# need to only mention family name here
font_family ComicShannsMonoNerdFont
# font_family UbuntuMonoNerdFontMono
# font_family JetBrainsMonoNerdFontMono
bold_font auto
italic_font auto
bold_italic_font auto
font_size 18


# Remap font change
map ctrl+= change_font_size all +1.0
map ctrl+- change_font_size all -1.0

# Block cursor
cursor_shape block
cursor_blink_interval 0
# cursor_beam_thickness 2.5
