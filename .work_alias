alias ele='cd /home/jos/repos/elephant'

alias task='cd /home/jos/repos/tasks-diary'

alias scs='cd /home/jos/.config/i3/screen_scripts/'

alias repos='cd /home/jos/repos/'

alias sand='cd /home/jos/sandbox'

alias tasks='nvim /home/jos/repos/tasks-diary/2026/june_26.md'

# Temporary alias
alias ci='ele && nvim /home/jos/repos/elephant/.github/workflows/CI.yml'

pushsync() {
	git push "$@"
	rsync -av --delete --exclude='.git' \
	/home/jos/repos/gpu-convex-polytope-sampling/ nfzj:/home/jos_l/repos/paper/gpu-convex-polytope-sampling/
}

paperpush() {
	git push "$@" origin && echo "origin success"
	git push "$@" jugit && echo "jugit success"
	git push "$@" ibt72 && echo "ibt72 success"
	git push "$@" ham && echo "ham success"
}

alias paper='cd $HOME/repos/paper'

# sync gpu_sampling onto ibt82
alias gpusync="rsync --exclude='.git/' -rv /home/jos/repos/gpu-convex-polytope-sampling/ nfzj:/home/jos_l/repos/paper/gpu-convex-polytope-sampling/"
