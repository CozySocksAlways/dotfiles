[init]
	defaultBranch = main
[user]
	name = Harris Antony Jos
	email = ha.jos@fz-juelich.de

[alias]
	add-commit = !git add -A && git commit
	s = status
	b = branch
	l = log -8
	la = log --all --oneline --graph
	cam = commit -a -m
	cama = commit -a --amend
	sdate = show -s --format='%aD | %an | %s'
	lname = log --oneline --format='%aD | %an | %s'
[merge]
  tool = nvimdiff

[mergetool]
  prompt = false
  keepBackup = false

[mergetool "nvimdiff"]
  layout = "LOCAL,BASE,REMOTE / MERGED"

[log]
	decorate=auto
	abbrevCommit=true

[format]
	pretty=oneline
[credential "https://github.com"]
	helper = 
	helper = !/usr/bin/gh auth git-credential
[credential "https://gist.github.com"]
	helper = 
	helper = !/usr/bin/gh auth git-credential
